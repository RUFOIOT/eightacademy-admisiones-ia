        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-3-5-sonnet-20241022\",\n  \"max_tokens\": 1500,\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": \"Eres el Director de Admisiones de Eight Academy, el colegio más innovador del Ecuador. Redacta un mensaje de outreach PREMIUM para una familia de perfil NSE A (ingreso $7,000+/mes).\\n\\nPROSPECTO:\\n- Lugar: {{ $json.lead_name }}\\n- Tipo: {{ $json.lead_type }}\\n- Dirección: {{ $json.lead_address }}\\n- Sede más cercana: {{ $json.lead_sede }} (a {{ $json.lead_distancia }}km)\\n- Perfil: {{ $json.lead_perfil }}\\n- NSE: A (élite)\\n- Hook detectado: {{ $json.lead_hook }}\\n\\nEIGHT ACADEMY — PROPUESTA EXCLUSIVA NSE A:\\n✨ Educación más innovadora del Ecuador\\n🥽 Únicos con Aulas de Metaverso y Realidad Virtual\\n🚀 Emprendimientos Digitales como materia (único en Ecuador)\\n🌿 Zoo Botánica Academy (experiencia única)\\n🎓 Bilingüe desde Inicial\\n💰 Pensión: $350/mes | SIN MATRÍCULA 2026/2027\\n🏆 Becas de excelencia disponibles\\n\\nDEVUELVE JSON:\\n{\\n  \\\"subject\\\": \\\"asunto impactante máx 60 chars\\\",\\n  \\\"whatsapp_message\\\": \\\"mensaje WA informal pero premium, 3 párrafos, incluye emojis, menciona VR/metaverso/emprendimiento, CTA visita guiada\\\",\\n  \\\"email_body_html\\\": \\\"email HTML formal premium, 3-4 párrafos\\\",\\n  \\\"email_body_text\\\": \\\"versión texto\\\",\\n  \\\"value_prop_personalizada\\\": \\\"propuesta específica para este prospecto\\\",\\n  \\\"cta\\\": \\\"llamada a la acción específica\\\",\\n  \\\"promo_angle\\\": \\\"cómo presentar SIN MATRÍCULA para NSE A (no enfocarse en precio, más en exclusividad)\\\",\\n  \\\"follow_up_days\\\": 3\\\n}\"\n  }]\n}",
        "options": {}
      },
