    {
      "parameters": {
        "jsCode": "// Parsear respuesta de Claude (sea cual sea el NSE branch)\nconst aiResp = $input.first().json;\nconst rawText = aiResp.content?.[0]?.text || '{}';\nconst leadData = $('💾 Extraer Datos Lead').first().json;\n\nlet email = {};\ntry {\n  const cleaned = rawText.replace(/```json/gi,'').replace(/```/gi,'').trim();\n  email = JSON.parse(cleaned);\n} catch(e) {\n  email = { subject: `Eight Academy × ${leadData.lead_name}`, whatsapp_message: rawText.substring(0,500), follow_up_days: 5 };\n}\n\nreturn [{ json: {\n  ...leadData,\n  email_subject: email.subject || '',\n  whatsapp_msg: email.whatsapp_message || '',\n  email_html: email.email_body_html || '',\n  email_text: email.email_body_text || '',\n  value_prop: email.value_prop_personalizada || '',\n  cta: email.cta || '',\n  promo_angle: email.promo_angle || '',\n  follow_up_days: email.follow_up_days || 5,\n  outreach_date: new Date().toISOString()\n}}];\n"
      },
