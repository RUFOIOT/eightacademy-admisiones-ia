        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-3-5-sonnet-20241022\",\n  \"max_tokens\": 1500,\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": \"Eres el Director de Admisiones de Eight Academy. Redacta un mensaje para una familia NSE B+ ($3,500-7,000/mes).\\n\\nPROSPECTO:\\n- Lugar: {{ $json.lead_name }}\\n- Tipo: {{ $json.lead_type }}\\n- Dirección: {{ $json.lead_address }}\\n- Sede más cercana: {{ $json.lead_sede }}\\n- Perfil: {{ $json.lead_perfil }}\\n- NSE: B+\\n- Hook: {{ $json.lead_hook }}\\n\\nEIGHT ACADEMY:\\n🥽 Aulas de Metaverso y Realidad Virtual\\n🚀 Emprendimientos Digitales (único en Ecuador)\\n🌿 Zoo Botánica Academy\\n🎓 Bilingüe + Metodología Constructivista\\n💰 Pensión $350/mes\\n🎉 SIN MATRÍCULA para 2026/2027 (ahorro inmediato)\\n📚 Becas y Semibecas disponibles\\n\\nEste NSE valora: calidad+tecnología+futuro+diferenciación. Mencionar SIN MATRÍCULA como beneficio adicional pero no como gancho principal.\\n\\nDEVUELVE JSON:\\n{\\n  \\\"subject\\\": \\\"asunto\\\",\\n  \\\"whatsapp_message\\\": \\\"mensaje WA natural y cercano, menciona sin matrícula como ventaja extra\\\",\\n  \\\"email_body_html\\\": \\\"email HTML\\\",\\n  \\\"email_body_text\\\": \\\"texto plano\\\",\\n  \\\"value_prop_personalizada\\\": \\\"propuesta específica\\\",\\n  \\\"cta\\\": \\\"CTA específico\\\",\\n  \\\"promo_angle\\\": \\\"ángulo de la promo para este NSE\\\",\\n  \\\"follow_up_days\\\": 4\\\n}\"\n  }]\n}",
        "options": {}
      },
